target		<http://example.com/ontop/meter/meter_id={meter_id}> a <http://example.com/ontop/meter> ; <http://example.com/ontop/meter#meter_id> {meter_id}^^xsd:string ; <http://example.com/ontop/meter#space_id> {space_id}^^xsd:string ; <http://example.com/ontop/meter#meter_type> {meter_type}^^xsd:string . 
