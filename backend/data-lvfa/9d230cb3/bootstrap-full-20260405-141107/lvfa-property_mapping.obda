[PrefixDeclaration]
rdf:		http://www.w3.org/1999/02/22-rdf-syntax-ns#
rdfs:		http://www.w3.org/2000/01/rdf-schema#
owl:		http://www.w3.org/2002/07/owl#
xsd:		http://www.w3.org/2001/XMLSchema#
obda:		https://w3id.org/obda/vocabulary#

[MappingDeclaration] @collection [[
mappingId	MAPPING-ID1
target		<http://example.com/ontop/space_unit/space_id={space_id}> a <http://example.com/ontop/space_unit> ; <http://example.com/ontop/space_unit#space_id> {space_id}^^xsd:string ; <http://example.com/ontop/space_unit#project_id> {project_id}^^xsd:string ; <http://example.com/ontop/space_unit#billing_area> {billing_area}^^xsd:decimal ; <http://example.com/ontop/space_unit#building_area> {building_area}^^xsd:decimal . 
source		SELECT * FROM "space_unit"

mappingId	MAPPING-ID2
target		<http://example.com/ontop/space_unit/space_id={space_unit_space_id}> <http://example.com/ontop/space_unit#ref-project_id> <http://example.com/ontop/property_project/project_id={property_project_project_id}> . 
source		SELECT "space_unit"."space_id" AS "space_unit_space_id", "property_project"."project_id" AS "property_project_project_id" FROM "space_unit", "property_project" WHERE "space_unit"."project_id" = "property_project"."project_id"

mappingId	MAPPING-ID3
target		<http://example.com/ontop/subscription/subscr_id={subscr_id}> a <http://example.com/ontop/subscription> ; <http://example.com/ontop/subscription#subscr_id> {subscr_id}^^xsd:string ; <http://example.com/ontop/subscription#account_id> {account_id}^^xsd:string ; <http://example.com/ontop/subscription#space_id> {space_id}^^xsd:string ; <http://example.com/ontop/subscription#parking_id> {parking_id}^^xsd:string ; <http://example.com/ontop/subscription#bc_id> {bc_id}^^xsd:string ; <http://example.com/ontop/subscription#contract_id> {contract_id}^^xsd:string ; <http://example.com/ontop/subscription#subscr_start> {subscr_start}^^xsd:date ; <http://example.com/ontop/subscription#subscr_end> {subscr_end}^^xsd:date ; <http://example.com/ontop/subscription#subscr_status> {subscr_status}^^xsd:string . 
source		SELECT * FROM "subscription"

mappingId	MAPPING-ID4
target		<http://example.com/ontop/subscription/subscr_id={subscription_subscr_id}> <http://example.com/ontop/subscription#ref-account_id> <http://example.com/ontop/account/account_id={account_account_id}> . 
source		SELECT "subscription"."subscr_id" AS "subscription_subscr_id", "account"."account_id" AS "account_account_id" FROM "subscription", "account" WHERE "subscription"."account_id" = "account"."account_id"

